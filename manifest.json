{
  "manifest_version": 3,
  "name": "URLScanner",
  "version": "2.0",
  "description": "A heuristic URL risk analyser for Firefox. Checks for phishing patterns, suspicious domains, and optionally queries VirusTotal for live threat intel.",
  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://www.virustotal.com/*",
    "https://rdap.org/*"
  ],
  "action": {
    "default_title": "URLScanner",
    "default_popup": "popup.html"
  },
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "icons": {
    "48": "icons/icon48.png",
    "96": "icons/icon96.png"
  }
}
